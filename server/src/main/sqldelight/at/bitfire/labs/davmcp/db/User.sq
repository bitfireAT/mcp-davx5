CREATE TABLE user(
    id INTEGER PRIMARY KEY AUTOINCREMENT NOT NULL,
    name TEXT NOT NULL,
    email TEXT NOT NULL,
    defaultCalendarId INTEGER REFERENCES collection(id) ON DELETE SET NULL
);

CREATE INDEX user_name ON user(email);

getById:
SELECT * FROM user WHERE id=?;

getDefaultCalendarId:
SELECT defaultCalendarId FROM user WHERE id=?;

setDefaultCalendar:
UPDATE user SET defaultCalendarId=? WHERE id=?;