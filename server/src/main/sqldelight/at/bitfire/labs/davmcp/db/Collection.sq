CREATE TABLE collection (
    id INTEGER PRIMARY KEY AUTOINCREMENT NOT NULL,
    serviceId INTEGER NOT NULL REFERENCES service(id) ON DELETE CASCADE,
    url TEXT NOT NULL,
    displayName TEXT DEFAULT NULL
);

CREATE INDEX collection_serviceId ON collection(serviceId);

getByService:
SELECT * FROM collection WHERE serviceId=?;

getByServiceAndId:
SELECT c.* FROM collection c
JOIN service s ON c.serviceId = s.id
WHERE c.id = ?1 AND s.userId = ?2;